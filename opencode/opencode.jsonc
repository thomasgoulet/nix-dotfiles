{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-haiku-4-5",
  "default_agent": "build",
  "autoupdate": false,
  "mcp": {
    "nu-mcp": {
      "type": "local",
      "command": ["nu-mcp", "--tools-dir", "/home/thomas/.config/nu/tools", "--enable-run-nu"],
      "enabled": true,
    },
  },
  "provider": {
    "github-copilot": {
      "models": {
        "claude-haiku-4.5": {
          "options": {
            "toolStreaming": false,
          },
        },
        "claude-sonnet-4.5": {
          "options": {
            "toolStreaming": false,
          },
        },
      },
    },
  },
}